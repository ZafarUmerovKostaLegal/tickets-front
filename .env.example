# =============================================================================
# Публичная конфигурация фронта (Vite: только переменные с префиксом VITE_)
# =============================================================================
# Скопируйте файл:  copy .env.example .env   (или .env.local)
# Секреты сюда не кладутся — всё, что попадёт в сборку, видно в браузере.

# --- Общие (UI) -------------------------------------------------------------
VITE_APP_TITLE=Kosta Legal — Tickets
VITE_FAVICON_PATH=/vite.svg

# Google Fonts (можно заменить на свой CDN или оставить по умолчанию)
VITE_GOOGLE_FONTS_PRECONNECT=https://fonts.googleapis.com
VITE_GOOGLE_FONTS_PRECONNECT_STATIC=https://fonts.gstatic.com
VITE_GOOGLE_FONTS_STYLESHEET=https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap

# --- API и авторизация ------------------------------------------------------
# Пусто: в dev запросы идут на тот же origin, Vite проксирует /api → VITE_PROXY_TARGET.
# Заполнено: абсолютный URL шлюза БЕЗ суффикса /api/v1 (нормализуется в коде).
VITE_API_BASE_URL=

# true: сессия только через HttpOnly-cookie на шлюзе (без JWT в localStorage). Нужны AUTH_SET_SESSION_COOKIE на бэке и согласованный CORS/credentials.
# Для локального dev без cookie-сессии на шлюзе временно поставьте false.
VITE_USE_SESSION_COOKIE=true

# Цель прокси `/api` только для `npm run dev` (Vite).
VITE_PROXY_TARGET=http://127.0.0.1:1234

# Посещаемость: оставьте пустым, если API идёт через тот же шлюз (VITE_API_BASE_URL).
# Задавайте только если отдельный хост (и тот же origin/домен для cookie, что и шлюз).
VITE_ATTENDANCE_API_BASE=

# --- Курсы ЦБ РУз (расходы и др.) -------------------------------------------
# Клиент ходит за JSON сюда: в dev удобно `/cbu-json` (прокси Vite → VITE_CBU_PROXY_TARGET).
# В проде: `https://cbu.uz` или путь прокси на вашем домене, например `/cbu-json`.
VITE_CBU_ORIGIN=/cbu-json

# Цель прокси `/cbu-json` только для `npm run dev` (Vite).
VITE_CBU_PROXY_TARGET=https://cbu.uz

# --- Пример продакшена (Kosta Legal) -----------------------------------------
# SPA: https://tickets.kostalegal.com/ | Шлюз API: https://ticketsback.kostalegal.com
# VITE_API_BASE_URL=https://ticketsback.kostalegal.com
# VITE_USE_SESSION_COOKIE=true
# VITE_CBU_ORIGIN=https://cbu.uz

# --- Tauri Android (системные переменные, не Vite) --------------------------
# Локальная сборка APK: Android Studio / SDK, NDK, JDK 17, rustup target add …/android
# https://v2.tauri.app/start/prerequisites/#android
# В shell: ANDROID_HOME, NDK_HOME (и при необходимости JAVA_HOME).
# npm run android:init
# npm run android:build:apk  → release-APK с встроенным `dist` (без Vite), ставится на телефон.
# Файл *-unsigned.apk без подписи Android не устанавливает; в app/build.gradle.kts подпись:
# keystore (см. gen/android/keystore.properties.example) или автоматически debug-ключ.
# `tauri android dev` / чёрный экран с http://192.168…: Vite на ПК должен быть доступен (та же сеть) или
# npm run android:dev:usb (adb reverse) плюс запущенный `npm run dev`.
# gen/android: compileSdk/targetSdk 35 — в SDK Manager нужны Platform 35 и build-tools 35.x.
# При таймаутах к dl.google.com: VPN/прокси, либо установка пакетов офлайн через Android Studio.
