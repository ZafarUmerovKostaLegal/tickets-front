# Скопируйте в keystore.properties (файл не коммитится) и укажите путь к keystore.
# Путь storeFile — относительно каталога gen/android (рядом с settings.gradle).
#
# keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# keyAlias=upload
# password=********
# storeFile=upload-keystore.jks
